#:kivy 2.2.1
# ---------------------------------------------------------------------
# kolik.kv - Koyu Zümrüt Yeşili + Altın Sarısı tema
# ---------------------------------------------------------------------

<MatchRow>:
    orientation: "horizontal"
    size_hint_y: None
    height: dp(78)
    padding: dp(10)
    spacing: dp(8)
    canvas.before:
        Color:
            rgba: 0.063, 0.318, 0.235, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10]

    BoxLayout:
        orientation: "vertical"
        Label:
            text: root.home_team + " vs " + root.away_team
            color: 0.949, 0.937, 0.902, 1
            bold: True
            halign: "left"
            valign: "middle"
            text_size: self.width, None
            shorten: True
            shorten_from: "right"
            max_lines: 2
            font_size: "15sp"
        Label:
            text: root.league + "  |  " + root.kickoff
            color: 0.831, 0.686, 0.216, 0.85
            font_size: "11sp"
            halign: "left"
            valign: "middle"
            text_size: self.width, None
            shorten: True
            shorten_from: "right"

    Button:
        id: select_btn
        text: "Analiz Et"
        size_hint_x: None
        width: dp(100)
        background_normal: ""
        background_color: 0.831, 0.686, 0.216, 1
        color: 0.043, 0.239, 0.180, 1
        bold: True
        font_size: "12sp"


<KolikScreenManager>:

<BultenScreen>:
    name: "bulten"
    canvas.before:
        Color:
            rgba: 0.043, 0.239, 0.180, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "vertical"
        padding: dp(14)
        spacing: dp(8)

        Label:
            text: "KOLIK"
            font_size: "28sp"
            bold: True
            color: 0.831, 0.686, 0.216, 1
            size_hint_y: None
            height: dp(42)

        Label:
            text: "Istatistiksel Mac Analiz Motoru (Poisson Modeli)"
            font_size: "12sp"
            color: 0.949, 0.937, 0.902, 0.75
            size_hint_y: None
            height: dp(20)

        BoxLayout:
            size_hint_y: None
            height: dp(46)
            spacing: dp(6)

            Button:
                text: "<"
                size_hint_x: None
                width: dp(48)
                background_normal: ""
                background_color: 0.063, 0.318, 0.235, 1
                color: 0.831, 0.686, 0.216, 1
                bold: True
                on_release: root.shift_date(-1)

            Label:
                text: root.date_display
                color: 0.949, 0.937, 0.902, 1
                font_size: "14sp"
                halign: "center"
                valign: "middle"
                text_size: self.size

            Button:
                text: ">"
                size_hint_x: None
                width: dp(48)
                background_normal: ""
                background_color: 0.063, 0.318, 0.235, 1
                color: 0.831, 0.686, 0.216, 1
                bold: True
                on_release: root.shift_date(1)

        Button:
            text: "Yenile"
            size_hint_y: None
            height: dp(46)
            background_normal: ""
            background_color: 0.831, 0.686, 0.216, 1
            color: 0.043, 0.239, 0.180, 1
            bold: True
            font_size: "14sp"
            on_release: root.refresh_fixtures()

        Label:
            text: root.status_text
            size_hint_y: None
            height: max(dp(24), self.texture_size[1] + dp(8))
            color: 0.831, 0.686, 0.216, 1
            font_size: "12sp"
            halign: "left"
            valign: "top"
            text_size: self.width, None

        ScrollView:
            do_scroll_x: False
            BoxLayout:
                id: match_list
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(8)
                padding: [0, dp(4)]

        Label:
            text: "Uyari: Bu uygulama bahis sitelerinden veri cekmez. Tum tahminler istatistiksel olasiliktir, garanti degildir."
            size_hint_y: None
            height: dp(36)
            font_size: "9sp"
            color: 0.949, 0.937, 0.902, 0.55
            halign: "center"
            text_size: self.width, None


<AnalizScreen>:
    name: "analiz"
    canvas.before:
        Color:
            rgba: 0.043, 0.239, 0.180, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "vertical"
        padding: dp(14)
        spacing: dp(10)

        BoxLayout:
            size_hint_y: None
            height: dp(44)
            spacing: dp(8)

            Button:
                text: "< Bultene Don"
                size_hint_x: None
                width: dp(130)
                background_normal: ""
                background_color: 0.063, 0.318, 0.235, 1
                color: 0.831, 0.686, 0.216, 1
                on_release: app.root.current = "bulten"

        Label:
            text: root.home_team + "  vs  " + root.away_team
            bold: True
            color: 0.949, 0.937, 0.902, 1
            font_size: "16sp"
            size_hint_y: None
            height: dp(50)
            halign: "center"
            valign: "middle"
            text_size: self.width, None

        Label:
            text: root.status_text
            size_hint_y: None
            height: max(dp(26), self.texture_size[1] + dp(10))
            color: 0.831, 0.686, 0.216, 1
            halign: "left"
            valign: "top"
            text_size: self.width, None

        ScrollView:
            do_scroll_x: False
            BoxLayout:
                id: results_box
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(4)
                padding: [dp(4), dp(6)]
